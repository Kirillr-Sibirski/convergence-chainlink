# CRE Environment Variables
# NEVER commit the .env file to git!

# Ethereum Private Key (for on-chain writes)
# Get testnet ETH from: https://sepoliafaucet.com/
CRE_ETH_PRIVATE_KEY=your_private_key_here

# CRE Target Environment
CRE_TARGET=staging

# OpenRouter API Key (Unified API for all AI models)
# Get API key from: https://openrouter.ai/
# This ONE key provides access to Claude, GPT, Gemini, and Grok
OPENROUTER_API_KEY_VAR=your_openrouter_api_key_here
