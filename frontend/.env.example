# WalletConnect Project ID (used by AppKit/wallet modal)
# Get from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# CRE HTTP trigger endpoint (from deployed Chainlink CRE workflow)
NEXT_PUBLIC_CRE_HTTP_TRIGGER_URL=https://your-cre-http-trigger-endpoint

# Optional bearer key if your CRE HTTP endpoint is protected
NEXT_PUBLIC_CRE_HTTP_TRIGGER_KEY=
