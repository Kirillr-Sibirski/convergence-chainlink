# WalletConnect Project ID (used by AppKit/wallet modal)
# Get from https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Tenderly Virtual TestNet config
NEXT_PUBLIC_RPC_URL=https://virtual.mainnet.eu.rpc.tenderly.co/your-virtual-testnet-id
NEXT_PUBLIC_CHAIN_ID=9993
NEXT_PUBLIC_NETWORK_NAME=Tenderly Virtual TestNet
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://dashboard.tenderly.co/explorer/vnet/your-virtual-testnet-id
# Optional direct transaction URL prefix (must include trailing slash)
NEXT_PUBLIC_EXPLORER_TX_BASE_URL=

# Deployed contracts
NEXT_PUBLIC_ORACLE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COLLATERAL_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COLLATERAL_SYMBOL=USDC
NEXT_PUBLIC_COLLATERAL_DECIMALS=6

# CRE HTTP trigger endpoint (from deployed Chainlink CRE workflow)
NEXT_PUBLIC_CRE_HTTP_TRIGGER_URL=https://your-cre-http-trigger-endpoint

# Optional bearer key if your CRE HTTP endpoint is protected
NEXT_PUBLIC_CRE_HTTP_TRIGGER_KEY=

# World ID (IDKit proof request in frontend; proof is verified onchain by AletheiaMarket)
# App ID from World Developer Portal (e.g. app_staging_xxxxx)
WORLD_APP_ID=app_staging_your_app_id
# RP ID from Developer Portal (e.g. rp_xxxxx)
WORLD_RP_ID=rp_your_rp_id
# Action configured in World app
WORLD_ID_ACTION=create-new-market
# Server-only RP signing key used by /api/rp-signature
RP_SIGNING_KEY=your_rp_signing_key_hex

# Optional public action override for the client widget (falls back to WORLD_ID_ACTION)
NEXT_PUBLIC_WORLD_ID_ACTION=create-new-market
# Optional World ID environment for IDKit widget (production|staging). Default is staging.
NEXT_PUBLIC_WORLD_ID_ENV=staging
