# Thirdweb Client ID (Required for Web3 RPC access)
# Get free client ID at: https://thirdweb.com/dashboard/settings/api-keys
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id_here

# OpenRouter API Key (for AI question validation)
# Get API key at: https://openrouter.ai/
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here
